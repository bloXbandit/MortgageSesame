# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./mortgagesesame.db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_USE_openssl_rand_-hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o
AI_FAST_MODEL=gpt-4o-mini

# ── ElevenLabs ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_AGENT_VOICE_NAME=
AGENT_PERSONA_NAME=Kenny        # what the voice agent calls itself — paste into ElevenLabs system prompt

# ── SignalWire (SMS — consent-gated only) ───────────────────────────────────
SIGNALWIRE_ACCOUNT_SID=
SIGNALWIRE_AUTH_TOKEN=
SIGNALWIRE_FROM_NUMBER=
SIGNALWIRE_SPACE=

# ── Twilio (SMS alternative — set CAMPAIGN_SMS_PROVIDER=twilio to activate) ──
# Account SID + Auth Token: console.twilio.com → Account Info
# From number: a Twilio phone number or messaging service SID
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Cal.com Webhook (optional secret — set in Cal.com → Webhooks → Secret) ──
CALCOM_WEBHOOK_SECRET=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=MortgageSesame

# ── Social (legacy keys — keep for backwards compat) ─────────────────────────
# NOTE: The video pipeline uses META_ACCESS_TOKEN / META_IG_USER_ID / META_PAGE_ID
# (unified Graph API token). If you already set INSTAGRAM_ACCESS_TOKEN /
# FACEBOOK_PAGE_ACCESS_TOKEN, they are the same token — just duplicate the value.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
LINKEDIN_ACCESS_TOKEN=
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_REFRESH_TOKEN=

# ── Content Video Pipeline — Mode Switches ────────────────────────────────────
# SAFE DEFAULTS: both set to "mock" — no real API calls, no real posts go out.
# Change to activate live pipelines.
#
#   CAMPAIGN_VIDEO_PROVIDER:  mock | heygen
#   CONTENT_PUBLISH_MODE:     mock | live
#
CAMPAIGN_VIDEO_PROVIDER=mock
CONTENT_PUBLISH_MODE=mock

# ── Media Storage ─────────────────────────────────────────────────────────────
# Local directory where generated MP3s and video assets are saved.
# Served as static files at /media/  (e.g. http://localhost:8000/media/abc.mp3)
# ⚠️  For publishing to TikTok / Instagram the BACKEND_URL must be publicly
#     reachable — localhost URLs will be rejected by Meta/TikTok pull APIs.
#     Use ngrok, Render, Railway, or Fly.io for dev tunneling.
MEDIA_STORAGE_PATH=./media

# ── HeyGen — Avatar Video Generation ─────────────────────────────────────────
# Sign up at https://heygen.com  → Settings → API Key
# Avatar ID: Studio → Avatars → click your avatar → copy "Avatar ID"
# Voice ID (optional): use a HeyGen built-in voice, or leave blank and set
#   HEYGEN_ELEVENLABS_VOICE_ID to use your ElevenLabs voice inside HeyGen.
# HEYGEN_TEST_MODE=true skips real API calls and returns a mock video_id.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
HEYGEN_ELEVENLABS_VOICE_ID=
HEYGEN_TEST_MODE=true

# ── AI Image / Avatar Generation — Flyers & Marketing Assets ─────────────────
#
# AVATAR_PROVIDER controls which AI generates your face/attire image.
#   auto        — tries openai → fal → replicate → passthrough (recommended)
#   openai      — gpt-image-1 image editing (uses existing OPENAI_API_KEY)
#   fal         — flux-pulid, best face consistency (needs FAL_API_KEY below)
#   replicate   — photomaker-v2 backup (needs REPLICATE_API_TOKEN below)
#   passthrough — no AI, uses your photo as-is (free, instant, for testing)
#
AVATAR_PROVIDER=auto

# ── Background Removal ───────────────────────────────────────────────────────
# After the AI generates your avatar, background removal cuts you out cleanly
# so you're composited onto the flyer with no background bleed-in.
#
# Provider chain (first available wins):
#   1. rembg        — local, zero cost. Install: pip install rembg
#                     Requires Python ≤3.11 (llvmlite build dep)
#   2. remove.bg    — API service. 50 free images/month. Works on Python 3.13.
#                     Sign up: https://remove.bg → Dashboard → API Key
#   3. passthrough  — no removal (flyer still works, just less clean edges)
#
REMOVE_BG_API_KEY=

# fal.ai — best face-consistent avatar generation
# Sign up: https://fal.ai → Dashboard → API Keys
FAL_API_KEY=

# Replicate — backup avatar generation
# Sign up: https://replicate.com → Account Settings → API Tokens
REPLICATE_API_TOKEN=

# If no AI provider key is set, the system uses your reference photo directly
# (passthrough). Still builds a fully branded flyer — good for quick testing.

# ── Bannerbear — Flyer Compositing (professional-grade templates) ─────────────
# Sign up at https://bannerbear.com → API → copy API key
# Set FLYER_COMPOSER=bannerbear to route flyer compositing through Bannerbear.
# Falls back to Pillow automatically if Bannerbear fails or a template ID is missing.
#
# Template setup (do once in Bannerbear editor):
#   Create 1 template per format. Name layers EXACTLY:
#     avatar       — image layer  (your face)
#     headline     — text layer
#     subheadline  — text layer
#     cta_text     — text layer
#     nmls_text    — text layer   (auto-filled: "NMLS # · Name · Equal Housing")
#     brand_name   — text layer   (auto-filled: app name)
#   Canvas sizes: social_square=1080×1080, facebook_banner=1200×628,
#                 story=1080×1920, wide_banner=1500×500
#
# ⚠️  Bannerbear pulls your avatar by URL. BACKEND_URL must be publicly reachable
#     (use ngrok/Render/Railway for local dev). Localhost URLs will fail silently
#     and the system will fall back to Pillow compositing.
#
FLYER_COMPOSER=pillow
BANNERBEAR_API_KEY=
BANNERBEAR_TEMPLATE_ID_SOCIAL_SQUARE=
BANNERBEAR_TEMPLATE_ID_FACEBOOK_BANNER=
BANNERBEAR_TEMPLATE_ID_STORY=
BANNERBEAR_TEMPLATE_ID_WIDE_BANNER=

# ── Creatomate — Video Assembly / Final Render ────────────────────────────────
# Sign up at https://creatomate.com  → API → copy API key
# Templates: create a template for each platform in the Creatomate editor,
#   then paste each template's ID here.  See README §Creatomate for details.
CREATOMATE_API_KEY=
CREATOMATE_TEMPLATE_ID_TIKTOK=
CREATOMATE_TEMPLATE_ID_REELS=
CREATOMATE_TEMPLATE_ID_LINKEDIN=

# ── Meta Graph API — Instagram Reels + Facebook ───────────────────────────────
# One long-lived Page token works for both Instagram Reels and Facebook.
# How to get:
#   1. developers.facebook.com → your app → Graph API Explorer
#   2. Select your Page → generate token with pages_manage_posts +
#      instagram_content_publish + instagram_basic permissions
#   3. Exchange for a long-lived token (60-day expiry; set up a cron to refresh)
# META_IG_USER_ID: Instagram → Settings → Account type → Professional → see IG User ID
#   OR: GET /{page_id}?fields=instagram_business_account from Graph API Explorer
# META_PAGE_ID: your Facebook Page numeric ID (shown in Page settings URL)
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_PAGE_ID=

# ── TikTok Content Posting API v2 ─────────────────────────────────────────────
# Requires a TikTok for Developers app with Content Posting API access approved.
# Steps:
#   1. developers.tiktok.com → Create App → request "Content Posting API" scope
#   2. Implement OAuth 2.0 PKCE flow to get an access token for your creator account
#   3. Paste access_token + open_id (the user identifier) here
# ⚠️  TikTok does NOT auto-approve Content Posting API — expect 1-2 week review.
# TIKTOK_OPEN_ID is the creator user identifier returned in the OAuth token response.
TIKTOK_OPEN_ID=
# TIKTOK_ACCESS_TOKEN already set above in Social section — same value used here

# ── LinkedIn Marketing API ────────────────────────────────────────────────────
# Steps:
#   1. developer.linkedin.com → Create App → request w_member_social permission
#   2. OAuth 2.0 3-legged flow to get token for your personal profile (not company page)
#   3. GET https://api.linkedin.com/v2/me → copy "id" field as LINKEDIN_PERSON_ID
#      (format: "urn:li:person:XXXXXXX" — paste the full URN)
# LINKEDIN_ACCESS_TOKEN already set above in Social section — same value used here
LINKEDIN_PERSON_ID=

# ── Content Intelligence — Cost Tracking ──────────────────────────────────────
# Used by the content agent's performance analysis to estimate video production spend.
# Adjust to match your actual Heygen/Creatomate invoices.
COST_HEYGEN_PER_MIN=0.10
COST_CREATOMATE_RENDER=0.05

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=MortgageSesame
PUBLIC_SITE_URL=http://localhost:5173
ADMIN_APP_URL=http://localhost:5174
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Agent ────────────────────────────────────────────────────────────────────
AGENT_API_KEY=CHANGE_ME_agent_secret_key
AGENT_WEBHOOK_URL=

# ── Cal.com / Booking ────────────────────────────────────────────────────────
CALCOM_LINK=

# ── Campaign Outreach — Channel Providers ─────────────────────────────────────
# Each channel defaults to "mock" — safe for development.
# Change to a real provider name to activate live sends.
#
# Direct mail:  mock | lob | postgrid
# Email:        mock | sendgrid | resend
# SMS:          mock | signalwire | twilio   (TCPA consent required — do not enable without consent gate)
# Property data: mock | attom

CAMPAIGN_DIRECT_MAIL_PROVIDER=mock
CAMPAIGN_EMAIL_PROVIDER=mock
CAMPAIGN_SMS_PROVIDER=mock
CAMPAIGN_PROPERTY_PROVIDER=mock

# ── Direct Mail — Lob ─────────────────────────────────────────────────────────
LOB_API_KEY=

# ── Direct Mail — PostGrid ────────────────────────────────────────────────────
POSTGRID_API_KEY=

# ── Campaign email provider ───────────────────────────────────────────────────
# Options: mock (logs only) | gmail (real sends via SMTP) | resend | sendgrid
CAMPAIGN_EMAIL_PROVIDER=mock

# ── Email — Gmail SMTP (use until Resend is ready) ───────────────────────────
# Uses your existing SMTP_HOST/PORT/USER/PASSWORD credentials above.
# Gmail requires an App Password (not your login password):
#   Google Account → Security → 2-Step Verification → App Passwords
# Flip to: CAMPAIGN_EMAIL_PROVIDER=gmail
# Limit: ~500 sends/day on a free Gmail account.

# ── Email — Resend (scale option) ────────────────────────────────────────────
# Flip to: CAMPAIGN_EMAIL_PROVIDER=resend
RESEND_API_KEY=

# ── Email — SendGrid ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=
# Sender identity (used by all email providers)
CAMPAIGN_FROM_EMAIL=
CAMPAIGN_FROM_NAME=MortgageSesame

# ── Property Data — ATTOM ─────────────────────────────────────────────────────
ATTOM_API_KEY=

# ── Banker contact info (used in email/SMS copy) ──────────────────────────────
BANKER_PHONE=

# ── Campaign Analytics — Cost Assumptions ────────────────────────────────────
# Used in /outreach/analytics to estimate spend and ROI.
# Set these to match your actual provider invoices.
COST_PER_EMAIL=0.003
COST_PER_DIRECT_MAIL=1.50
COST_PER_SMS=0.015
COMMISSION_ESTIMATE=8000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mortgagesesame
# Supabase: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_USE_openssl_rand_-hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o
AI_FAST_MODEL=gpt-4o-mini

# ── ElevenLabs ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=           # Your agent's default voice ID
ELEVENLABS_AGENT_VOICE_NAME=   # e.g. "Aria" or custom cloned voice name

# ── Twilio (SMS — consent-gated only) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=            # Your agent's dedicated Twilio number
TWILIO_MESSAGING_SERVICE_SID=  # Optional: for campaign messaging

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=MortgageSesame

# ── Social ───────────────────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
LINKEDIN_ACCESS_TOKEN=
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_REFRESH_TOKEN=

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local           # local | s3 | supabase
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development             # development | production
APP_NAME=MortgageSesame
PUBLIC_SITE_URL=http://localhost:5173
ADMIN_APP_URL=http://localhost:5174
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Agent ────────────────────────────────────────────────────────────────────
AGENT_API_KEY=CHANGE_ME_agent_secret_key
AGENT_WEBHOOK_URL=              # Where agent POSTs results back (optional)

# ── Calendly / Booking ───────────────────────────────────────────────────────
CALENDLY_LINK=https://calendly.com/your-link
